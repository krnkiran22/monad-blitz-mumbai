# Copy to .env.local and fill in after deploying Arena.sol to Monad Testnet.

# Deployed Arena.sol contract address (live on Monad Testnet)
NEXT_PUBLIC_ARENA_ADDRESS=0x9fDF1758D5EeA606C4f2b9870A8a90f2CcB5fe7f

# ERC-8004 "Trustless Agents" registries (deploy AgentRegistry.sol).
# Identity = the agent passport NFT; Reputation = the on-chain track record.
NEXT_PUBLIC_IDENTITY_REGISTRY_ADDRESS=
NEXT_PUBLIC_REPUTATION_REGISTRY_ADDRESS=

# Set to "false" to disable betting entirely (lobby skips betting, match starts
# directly). Any other value or unset keeps the full bet-then-watch flow.
NEXT_PUBLIC_ENABLE_BETTING=true

# PlayroomKit game id (free, no credit card) for multiplayer rooms.
# Get one at https://dev.joinplayroom.com -> New Project -> Configuration -> General.
# Leave blank to try dev mode (works on older PlayroomKit; newer versions require this).
NEXT_PUBLIC_PLAYROOM_GAME_ID=
